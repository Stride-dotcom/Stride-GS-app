VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_API_TOKEN=your-api-token-here

# Dev-only: when true AND the app is running under `npm run dev` (Vite DEV
# mode), AuthContext short-circuits to a mock admin user so authenticated
# pages can be previewed without real login. Vite tree-shakes this block
# out of production builds — the flag has no effect in prod even if set.
# Leave unset or 'false' to use the normal Supabase login flow.
VITE_DEV_BYPASS_AUTH=false
