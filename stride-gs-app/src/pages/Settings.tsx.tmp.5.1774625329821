                        <td style={{ padding: '10px 14px' }}><span style={{ fontSize: 11, padding: '2px 10px', borderRadius: 10, fontWeight: 600, background: u.role === 'Admin' ? '#EDE9FE' : u.role === 'Staff' ? '#EFF6FF' : theme.colors.orangeLight, color: u.role === 'Admin' ? '#7C3AED' : u.role === 'Staff' ? '#1D4ED8' : theme.colors.orange }}>{u.role}</span></td>
                        <td style={{ padding: '10px 14px', color: u.client ? theme.colors.text : theme.colors.textMuted }}>{u.client || '\u2014'}</td>
                        <td style={{ padding: '10px 14px', textAlign: 'center' }}>{u.active ? <span style={{ color: '#15803D' }}>{'\u2713'}</span> : <span style={{ color: theme.colors.textMuted }}>{'\u2717'}</span>}</td>
                        <td style={{ padding: '10px 14px', color: theme.colors.textMuted }}>{u.lastLogin}</td>
                        <td style={{ padding: '10px 14px', textAlign: 'right' }}>
                          <div style={{ display: 'flex', gap: 6, justifyContent: 'flex-end' }}>
                            <button onClick={() => alert(`Toggle ${u.active ? 'deactivate' : 'activate'} for ${u.email} (Coming soon)`)} title={u.active ? 'Deactivate' : 'Activate'} style={{ background: 'none', border: 'none', cursor: 'pointer', color: theme.colors.textMuted, padding: 2 }}>{u.active ? <ToggleRight size={16} color="#15803D" /> : <ToggleLeft size={16} />}</button>
                            <button onClick={() => alert(`Remove ${u.email} (Coming soon)`)} title="Remove user" style={{ background: 'none', border: 'none', cursor: 'pointer', color: theme.colors.textMuted, padding: 2 }}><Trash2 size={14} /></button>
                          </div>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <div style={{ padding: 14, background: '#FFFBF5', border: '1px solid #FED7AA', borderRadius: 10, fontSize: 12, color: '#92400E', marginTop: 16, lineHeight: 1.6 }}>
                <strong>How it works:</strong> Users are stored in the "Users" tab of the Consolidated Billing sheet. Staff sign in with Google (@stridenw.com). Clients receive a magic link email — no password needed. New client users are automatically added during onboarding. Toggle Active to disable access without deleting the user.
              </div>
            </>
          )}

          {tab === 'pricing' && (
            <div style={card}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 }}>
                <div style={sectionTitle}>Service Rates by Class</div>
                <button onClick={() => alert('Coming soon — Edit rates')} style={{ padding: '6px 14px', fontSize: 12, fontWeight: 500, border: `1px solid ${theme.colors.border}`, borderRadius: 8, background: '#fff', cursor: 'pointer', fontFamily: 'inherit', color: theme.colors.textSecondary }}>Edit Rates</button>
              </div>
              <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 12 }}>
                <thead><tr style={{ borderBottom: `2px solid ${theme.colors.border}` }}>
                  <th style={{ padding: '8px 10px', textAlign: 'left', fontSize: 10, color: theme.colors.textMuted, textTransform: 'uppercase' }}>Code</th>
                  <th style={{ padding: '8px 10px', textAlign: 'left', fontSize: 10, color: theme.colors.textMuted, textTransform: 'uppercase' }}>Service</th>
                  {['XS', 'S', 'M', 'L', 'XL'].map(c => <th key={c} style={{ padding: '8px 10px', textAlign: 'right', fontSize: 10, color: theme.colors.textMuted, textTransform: 'uppercase' }}>{c}</th>)}
                </tr></thead>
                <tbody>{MOCK_PRICING.map(p => (
                  <tr key={p.code} style={{ borderBottom: `1px solid ${theme.colors.borderLight}` }}>
                    <td style={{ padding: '8px 10px', fontWeight: 600, fontFamily: 'monospace' }}>{p.code}</td>
                    <td style={{ padding: '8px 10px', color: theme.colors.textSecondary }}>{p.name}</td>
                    {[p.xs, p.s, p.m, p.l, p.xl].map((v, i) => <td key={i} style={{ padding: '8px 10px', textAlign: 'right' }}>${v.toFixed(2)}</td>)}
                  </tr>
                ))}</tbody>
              </table>
              <div style={{ marginTop: 16 }}>
                <div style={sectionTitle}>Class Map</div>
                <div style={{ display: 'flex', gap: 12 }}>
                  {[{ c: 'XS', vol: '≤10 cu ft' }, { c: 'S', vol: '11-25' }, { c: 'M', vol: '26-50' }, { c: 'L', vol: '51-75' }, { c: 'XL', vol: '76+' }].map(x => (
                    <div key={x.c} style={{ flex: 1, padding: '10px', background: theme.colors.bgSubtle, borderRadius: 8, textAlign: 'center' }}>
                      <div style={{ fontSize: 16, fontWeight: 700 }}>{x.c}</div>
                      <div style={{ fontSize: 10, color: theme.colors.textMuted, marginTop: 2 }}>{x.vol}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {tab === 'emails' && (
            <>
              <div style={{ ...sectionTitle, marginBottom: 16 }}>Email Templates ({MOCK_EMAILS.length})</div>
              {MOCK_EMAILS.map(e => (
                <div key={e.key} style={{ ...card, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                      <span style={{ fontSize: 13, fontWeight: 600 }}>{e.name}</span>
                      <span style={{ fontSize: 10, fontFamily: 'monospace', color: theme.colors.textMuted, background: theme.colors.bgSubtle, padding: '1px 6px', borderRadius: 4 }}>{e.key}</span>
                    </div>
                    <div style={{ fontSize: 12, color: theme.colors.textSecondary, marginTop: 3 }}>{e.desc}</div>
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 10 }}>
                    {e.active ? <CheckCircle2 size={16} color="#15803D" /> : <AlertCircle size={16} color={theme.colors.textMuted} />}
                    <button onClick={() => alert('Coming soon — Preview template')} style={{ padding: '5px 12px', fontSize: 11, fontWeight: 500, border: `1px solid ${theme.colors.border}`, borderRadius: 6, background: '#fff', cursor: 'pointer', fontFamily: 'inherit', color: theme.colors.textSecondary }}>Preview</button>
                  </div>
                </div>
              ))}
            </>
          )}

          {tab === 'integrations' && (
            <IntegrationsTab />
          )}

          {tab === 'notifications' && (
            <div style={card}>
              <div style={sectionTitle}>Notification Preferences</div>
              {[
                { label: 'Shipment received', desc: 'When a new shipment is completed', email: true, app: true },
                { label: 'Task completed', desc: 'When any task is marked complete', email: true, app: true },
                { label: 'Repair quote requested', desc: 'When a client requests a repair quote', email: true, app: true },
                { label: 'Will call past due', desc: 'When a scheduled will call passes its pickup date', email: false, app: true },
                { label: 'Storage charges generated', desc: 'When monthly storage billing runs', email: true, app: false },
                { label: 'Invoice approved', desc: 'When an invoice is approved in review', email: false, app: true },
              ].map(n => (
                <div key={n.label} style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '12px 0', borderBottom: `1px solid ${theme.colors.borderLight}` }}>
                  <div>
                    <div style={{ fontSize: 13, fontWeight: 500 }}>{n.label}</div>
                    <div style={{ fontSize: 11, color: theme.colors.textMuted }}>{n.desc}</div>
                  </div>
                  <div style={{ display: 'flex', gap: 16 }}>
                    <label style={{ display: 'flex', alignItems: 'center', gap: 4, fontSize: 11, color: theme.colors.textSecondary, cursor: 'pointer' }}><input type="checkbox" defaultChecked={n.email} style={{ accentColor: theme.colors.orange }} />Email</label>
                    <label style={{ display: 'flex', alignItems: 'center', gap: 4, fontSize: 11, color: theme.colors.textSecondary, cursor: 'pointer' }}><input type="checkbox" defaultChecked={n.app} style={{ accentColor: theme.colors.orange }} />In-App</label>
                  </div>
                </div>
              ))}
              <button onClick={() => alert('Coming soon')} style={{ marginTop: 16, padding: '10px 20px', fontSize: 13, fontWeight: 600, border: 'none', borderRadius: 8, background: theme.colors.orange, color: '#fff', cursor: 'pointer', fontFamily: 'inherit' }}>Save Preferences</button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
