/** 25. checkMarketingInbox — process replies, bounces, unsubscribes */
function handleCheckMarketingInbox_() {
  var lock = LockService.getScriptLock();
  if (!lock.tryLock(10000)) return errorResponse_("Could not acquire lock — try again", "LOCK_TIMEOUT");

  try {
    var ss = getCampaignSpreadsheet_();
    var ccSheet = ss.getSheetByName("Campaign Contacts");
    if (!ccSheet) return jsonResponse_({ repliesFound: 0, bouncesFound: 0, unsubscribesFound: 0 });

    var ccData = ccSheet.getDataRange().getValues();
    var ccHdr = {};
    ccData[0].forEach(function(h, i) { ccHdr[String(h || "").trim()] = i; });

    var unsubKeywords = ["unsubscribe", "stop", "remove me", "opt out", "opt-out",
      "take me off", "no more", "cancel subscription", "stop emailing"];

    var repliesFound = 0, bouncesFound = 0, unsubscribesFound = 0;
    var now = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyy-MM-dd HH:mm:ss");

    // Build lookup of CC rows by thread ID
    var threadMap = {};
    for (var i = 1; i < ccData.length; i++) {
      var tid = String(ccData[i][ccHdr["Gmail Thread ID"]] || "").trim();
      if (!tid) continue;
      var ccSt = String(ccData[i][ccHdr["Status"]] || "");
      if (ccSt === "Replied" || ccSt === "Bounced" || ccSt === "Unsubscribed") continue;
      threadMap[tid] = i; // 0-based data row index
    }

    // Check replies
    var threadIds = Object.keys(threadMap);
    for (var t = 0; t < threadIds.length; t++) {
      try {
        var thread = GmailApp.getThreadById(threadIds[t]);
        if (!thread) continue;
        var msgs = thread.getMessages();
        if (msgs.length <= 1) continue; // No reply

        var rowIdx = threadMap[threadIds[t]];
        var ccEmail = String(ccData[rowIdx][ccHdr["Contact Email"]] || "").trim().toLowerCase();

        // Check last reply message
        var lastMsg = msgs[msgs.length - 1];
        var replyFrom = String(lastMsg.getFrom() || "").toLowerCase();
        if (replyFrom.indexOf(ccEmail) < 0) continue; // Not from contact

        var replyBody = String(lastMsg.getPlainBody() || "").toLowerCase();
        var isUnsub = false;
        for (var u = 0; u < unsubKeywords.length; u++) {
          if (replyBody.indexOf(unsubKeywords[u]) >= 0) { isUnsub = true; break; }
        }

        if (isUnsub) {
          // Process as unsubscribe
          ccSheet.getRange(rowIdx + 1, ccHdr["Status"] + 1).setValue("Unsubscribed");
          ccSheet.getRange(rowIdx + 1, ccHdr["Unsubscribed"] + 1).setValue("TRUE");
          // Suppress globally
          var conFound = mkt_findContactRow_(ss, ccEmail);
          if (conFound) {
            mkt_patchRow_(conFound.sheet, conFound.sheetRow, conFound.hdrMap, {
              "Suppressed": "TRUE", "Suppression Reason": "Reply Keyword", "Suppression Date": now,
              "Unsubscribed": "TRUE", "Status": "Suppressed"
            });
          }
          var slSheet = ss.getSheetByName("Suppression Log");
          if (slSheet) slSheet.appendRow([now, ccEmail, "", "", "Reply Keyword", "Inbox Check"]);

          // Label
          try {
            var unsubLabel = GmailApp.getUserLabelByName("Stride/Campaign/Unsubscribed") || GmailApp.createLabel("Stride/Campaign/Unsubscribed");
            unsubLabel.addToThread(thread);
          } catch (le) {}

          unsubscribesFound++;
        } else {
          // Regular reply — suppress
          ccSheet.getRange(rowIdx + 1, ccHdr["Status"] + 1).setValue("Replied");
          ccSheet.getRange(rowIdx + 1, ccHdr["Replied"] + 1).setValue("TRUE");
          var conFound2 = mkt_findContactRow_(ss, ccEmail);
          if (conFound2) {
            mkt_patchRow_(conFound2.sheet, conFound2.sheetRow, conFound2.hdrMap, {
              "Replied": "TRUE", "Suppressed": "TRUE", "Suppression Reason": "Replied", "Status": "Suppressed"
            });
          }
          var slSheet2 = ss.getSheetByName("Suppression Log");
          if (slSheet2) slSheet2.appendRow([now, ccEmail, "", "", "Replied", "Inbox Check"]);

          try {
            var repliedLabel = GmailApp.getUserLabelByName("Stride/Campaign/Replied") || GmailApp.createLabel("Stride/Campaign/Replied");
            repliedLabel.addToThread(thread);
          } catch (le2) {}

          repliesFound++;
        }
      } catch (threadErr) {
        // Skip individual thread errors
      }
    }

    // Check bounces
    try {
      var bounceThreads = GmailApp.search("from:mailer-daemon newer_than:2d", 0, 50);
      var emailRegex = /[\w.+-]+@[\w.-]+\.[a-zA-Z]{2,}/g;

      // Build set of all contact emails for matching
      var conSheet = ss.getSheetByName("Contacts");
      var allContactEmails = {};
      if (conSheet) {
        var conRows = sheetToObjects_(conSheet);
        for (var ci = 0; ci < conRows.length; ci++) {
          var ce = String(conRows[ci]["Email"] || "").trim().toLowerCase();
          if (ce) allContactEmails[ce] = true;
        }
      }

      for (var b = 0; b < bounceThreads.length; b++) {
        var bMsgs = bounceThreads[b].getMessages();
        for (var bm = 0; bm < bMsgs.length; bm++) {
          var bBody = String(bMsgs[bm].getPlainBody() || "");
          var matches = bBody.match(emailRegex);
          if (!matches) continue;
          for (var mx = 0; mx < matches.length; mx++) {
            var bounceEmail = matches[mx].toLowerCase();
            if (!allContactEmails[bounceEmail]) continue;

            // Check if already bounced
            var conFound3 = mkt_findContactRow_(ss, bounceEmail);
            if (!conFound3) continue;
            if (String(conFound3.data[conFound3.rowIdx][conFound3.hdrMap["Bounced"]] || "").toUpperCase() === "TRUE") continue;

            // Suppress
            mkt_patchRow_(conFound3.sheet, conFound3.sheetRow, conFound3.hdrMap, {
              "Bounced": "TRUE", "Suppressed": "TRUE", "Suppression Reason": "Bounced",
              "Suppression Date": now, "Status": "Suppressed"
            });

            // Update all CC rows for this email
            for (var ccr = 1; ccr < ccData.length; ccr++) {
              if (String(ccData[ccr][ccHdr["Contact Email"]] || "").trim().toLowerCase() === bounceEmail) {
                ccSheet.getRange(ccr + 1, ccHdr["Bounced"] + 1).setValue("TRUE");
                var ccSt2 = String(ccData[ccr][ccHdr["Status"]] || "");
                if (ccSt2 === "Pending" || ccSt2 === "Sent" || ccSt2 === "Follow-Up Scheduled") {
                  ccSheet.getRange(ccr + 1, ccHdr["Status"] + 1).setValue("Bounced");
                }
              }
            }

            var slSheet3 = ss.getSheetByName("Suppression Log");
            if (slSheet3) slSheet3.appendRow([now, bounceEmail, "", "", "Bounced", "Inbox Check"]);

            try {
              var bounceLabel = GmailApp.getUserLabelByName("Stride/Campaign/Bounced") || GmailApp.createLabel("Stride/Campaign/Bounced");
              bounceLabel.addToThread(bounceThreads[b]);
            } catch (le3) {}

            bouncesFound++;
          }
        }
      }
    } catch (bounceErr) {
      // Bounce detection error — non-fatal
    }

    // Update stats for all active campaigns
    var cmpSheet = ss.getSheetByName("Campaigns");
    if (cmpSheet) {
      var cmpRows = sheetToObjects_(cmpSheet);
      for (var cm = 0; cm < cmpRows.length; cm++) {
        if (String(cmpRows[cm]["Status"] || "") === "Active") {
          mkt_updateCampaignStats_(ss, String(cmpRows[cm]["Campaign ID"] || ""));
        }
      }
    }

    return jsonResponse_({ repliesFound: repliesFound, bouncesFound: bouncesFound, unsubscribesFound: unsubscribesFound });
  } finally {
    lock.releaseLock();
  }
}

// ═══════════════════════════════════════════════════════════════════════════════
// QBO (QuickBooks Online) Integration — v38.19.0
// OAuth 2.0 Authorization Code flow + Customer/Sub-Job Auto-Create + Invoice Push
// ═══════════════════════════════════════════════════════════════════════════════

var QBO_RETRYABLE_STATUS_CODES_ = [429, 500, 502, 503, 504];

// ─── QBO OAuth Helpers ──────────────────────────────────────────────────────

/**
 * Escape single quotes for QBO query string interpolation.
 * All QBO queries MUST use this on user-supplied values.
 */
function qbo_escapeQueryString_(str) {
  return String(str || "").replace(/'/g, "\\'");
}

/**
 * Generate QBO authorization URL. Stores nonce for CSRF validation.
 */
function qbo_getAuthUrl_() {
  var clientId    = prop_("QBO_CLIENT_ID");
  var redirectUri = prop_("QBO_REDIRECT_URI");
  if (!clientId)    throw new Error("QBO_CLIENT_ID not configured in Script Properties");
  if (!redirectUri) throw new Error("QBO_REDIRECT_URI not configured in Script Properties");

  // Generate 32-char alphanumeric nonce
  var chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
  var nonce = "";
  for (var i = 0; i < 32; i++) {
    nonce += chars.charAt(Math.floor(Math.random() * chars.length));
  }
  PropertiesService.getScriptProperties().setProperty("QBO_STATE_NONCE", nonce);

  return "https://appcenter.intuit.com/connect/oauth2" +
    "?client_id=" + encodeURIComponent(clientId) +
    "&redirect_uri=" + encodeURIComponent(redirectUri) +
    "&response_type=code" +
    "&scope=com.intuit.quickbooks.accounting" +
    "&state=" + nonce;
}

/**
 * Exchange authorization code for access + refresh tokens.
 * Validates state nonce to prevent CSRF. Stores tokens in PropertiesService.
 */
function qbo_exchangeCode_(code, state, realmId) {
  if (!code)  return { success: false, error: "Missing authorization code" };
  if (!state) return { success: false, error: "Missing state parameter" };

  var storedNonce = prop_("QBO_STATE_NONCE");
  if (!storedNonce || state !== storedNonce) {
    return { success: false, error: "Invalid state — possible CSRF. Please try connecting again." };
  }

  var clientId     = prop_("QBO_CLIENT_ID");
  var clientSecret = prop_("QBO_CLIENT_SECRET");
  var redirectUri  = prop_("QBO_REDIRECT_URI");

  if (!clientId || !clientSecret) {
    return { success: false, error: "QBO_CLIENT_ID or QBO_CLIENT_SECRET not configured" };
  }

  try {
    var response = UrlFetchApp.fetch("https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer", {
      method: "post",
      headers: {
        "Authorization": "Basic " + Utilities.base64Encode(clientId + ":" + clientSecret),
        "Accept": "application/json"
      },
      contentType: "application/x-www-form-urlencoded",
      payload: "grant_type=authorization_code" +
        "&code=" + encodeURIComponent(code) +
        "&redirect_uri=" + encodeURIComponent(redirectUri),
      muteHttpExceptions: true
    });

    var status = response.getResponseCode();
    var body = JSON.parse(response.getContentText());

    if (status !== 200 || !body.access_token) {
      return { success: false, error: "Token exchange failed: " + (body.error_description || body.error || "HTTP " + status) };
    }

    var props = PropertiesService.getScriptProperties();
    props.setProperty("QBO_ACCESS_TOKEN",  body.access_token);
    props.setProperty("QBO_REFRESH_TOKEN", body.refresh_token || "");
    if (realmId) props.setProperty("QBO_REALM_ID", realmId);
    props.deleteProperty("QBO_STATE_NONCE");

    return { success: true };
  } catch (e) {
    return { success: false, error: "Token exchange error: " + e.message };
  }
}

/**
 * Refresh an expired access token using the refresh token.
 * Returns new access token string or throws.
 */
function qbo_refreshToken_() {
  var refreshToken = prop_("QBO_REFRESH_TOKEN");
  if (!refreshToken) throw new Error("QBO not connected — re-authorize required");

  var clientId     = prop_("QBO_CLIENT_ID");
  var clientSecret = prop_("QBO_CLIENT_SECRET");

  var response = UrlFetchApp.fetch("https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer", {
    method: "post",
    headers: {
      "Authorization": "Basic " + Utilities.base64Encode(clientId + ":" + clientSecret),
      "Accept": "application/json"
    },
    contentType: "application/x-www-form-urlencoded",
    payload: "grant_type=refresh_token&refresh_token=" + encodeURIComponent(refreshToken),
    muteHttpExceptions: true
  });

  var status = response.getResponseCode();
  var body = JSON.parse(response.getContentText());

  if (status !== 200 || !body.access_token) {
    // Refresh token likely expired (100-day lifetime) — must re-authorize
    throw new Error("QBO token refresh failed — re-authorize required. " + (body.error_description || body.error || "HTTP " + status));
  }

  var props = PropertiesService.getScriptProperties();
  props.setProperty("QBO_ACCESS_TOKEN", body.access_token);
  if (body.refresh_token) props.setProperty("QBO_REFRESH_TOKEN", body.refresh_token);

  return body.access_token;
}

/**
 * Make an authenticated QBO API request with auto-retry and token refresh.
 * Matches stax_apiRequest_ backoff pattern: 3 attempts, 2s/4s/8s.
 */
function qbo_apiRequest_(method, path, payload, token, realmId) {
  var baseUrl = "https://quickbooks.api.intuit.com/v3/company/" + realmId + "/";
  var url = baseUrl + path;
  var currentToken = token;
  var backoffMs = [2000, 4000, 8000];
  var maxRetries = 3;

  for (var attempt = 0; attempt < maxRetries; attempt++) {
    try {
      var options = {
        method: method.toLowerCase(),
        headers: {
          "Authorization": "Bearer " + currentToken,
          "Accept": "application/json"
        },
        contentType: "application/json",
        muteHttpExceptions: true
      };

      if (payload && (method.toUpperCase() === "POST" || method.toUpperCase() === "PUT")) {
        options.payload = JSON.stringify(payload);
      }

      var response = UrlFetchApp.fetch(url, options);
      var status = response.getResponseCode();
      var bodyText = response.getContentText();
      var data = null;
      try { data = JSON.parse(bodyText); } catch (_) { /* non-JSON */ }

      // Success
      if (status >= 200 && status < 300) {
        return { success: true, status: status, data: data };
      }

      // 401 Unauthorized — refresh token and retry once
      if (status === 401 && attempt === 0) {
        currentToken = qbo_refreshToken_();
        continue; // retry immediately (no backoff for auth refresh)
      }

      // Non-retryable error
      if (QBO_RETRYABLE_STATUS_CODES_.indexOf(status) === -1) {
        var errMsg = "HTTP " + status;
        if (data && data.Fault && data.Fault.Error && data.Fault.Error.length > 0) {
          errMsg += ": " + data.Fault.Error[0].Message + (data.Fault.Error[0].Detail ? " — " + data.Fault.Error[0].Detail : "");
        } else if (bodyText) {
          errMsg += ": " + bodyText.substring(0, 300);
        }
        return { success: false, status: status, data: data, error: errMsg };
      }

      // Retryable — backoff
      if (attempt < maxRetries - 1) {
        Utilities.sleep(backoffMs[attempt]);
      }
    } catch (e) {
      if (attempt < maxRetries - 1) {
        Utilities.sleep(backoffMs[attempt]);
      } else {
        return { success: false, status: 0, data: null, error: "Network error: " + e.message };
      }
    }
  }

  return { success: false, status: 0, data: null, error: "QBO API: max retries exceeded" };
}

/**
 * Get a valid QBO access token, refreshing if needed.
 */
function qbo_getValidToken_() {
  var token = prop_("QBO_ACCESS_TOKEN");
  if (!token) throw new Error("Not connected to QuickBooks Online — please authorize in Settings → Integrations");

  var realmId = prop_("QBO_REALM_ID");
  if (!realmId) throw new Error("QBO_REALM_ID missing — please re-authorize");

  // Lightweight validation: try to read CompanyInfo
  var result = qbo_apiRequest_("GET", "companyinfo/" + realmId, null, token, realmId);
  if (result.success) return token;

  // If we get here with a 401, the retry inside qbo_apiRequest_ already refreshed
  // Check if the refresh succeeded by reading the new token
  var refreshedToken = prop_("QBO_ACCESS_TOKEN");
  if (refreshedToken && refreshedToken !== token) return refreshedToken;

  throw new Error("QBO token validation failed — please re-authorize");
}

/**
 * Check QBO connection status. Returns { connected, realmId, companyName }.
 */
function qbo_getStatus_() {
  var realmId = prop_("QBO_REALM_ID");
  if (!realmId) return { connected: false };

  try {
    var token = prop_("QBO_ACCESS_TOKEN");
    if (!token) return { connected: false };

    var result = qbo_apiRequest_("GET", "companyinfo/" + realmId, null, token, realmId);
    if (!result.success) return { connected: false, error: result.error };

    var companyName = "";
    if (result.data && result.data.CompanyInfo) {
      companyName = result.data.CompanyInfo.CompanyName || "";
    }

    return { connected: true, realmId: realmId, companyName: companyName };
  } catch (e) {
    return { connected: false, error: e.message };
  }
}

// ─── QBO Customer Lookup + Auto-Create ──────────────────────────────────────

/**
 * Search QBO for a customer by exact DisplayName.
 * Returns the first matching customer object or null.
 */
function qbo_searchCustomer_(displayName, token, realmId) {
  var escaped = qbo_escapeQueryString_(displayName);
  var query = "SELECT Id, DisplayName, FullyQualifiedName FROM Customer WHERE DisplayName = '" + escaped + "'";
  var result = qbo_apiRequest_("GET", "query?query=" + encodeURIComponent(query), null, token, realmId);

  if (!result.success) return null;
  var qr = result.data && result.data.QueryResponse;
  if (qr && qr.Customer && qr.Customer.length > 0) {
    return qr.Customer[0];
  }
  return null;
}

/**
 * Search QBO for a sub-job by DisplayName under a specific parent.
 * QBO query doesn't reliably filter by ParentRef, so we filter client-side.
 */
function qbo_searchSubJob_(displayName, parentId, token, realmId) {
  var escaped = qbo_escapeQueryString_(displayName);
  var query = "SELECT Id, DisplayName, FullyQualifiedName, ParentRef FROM Customer WHERE DisplayName = '" + escaped + "' AND Active = true";
  var result = qbo_apiRequest_("GET", "query?query=" + encodeURIComponent(query), null, token, realmId);

  if (!result.success) return null;
  var qr = result.data && result.data.QueryResponse;
  if (!qr || !qr.Customer) return null;

  for (var i = 0; i < qr.Customer.length; i++) {
    var c = qr.Customer[i];
    if (c.ParentRef && String(c.ParentRef.value) === String(parentId)) {
      return c;
    }
  }
  return null;
}

/**
 * Create a QBO customer (or sub-job if parentId provided).
 * On 400 duplicate: returns { error: 'DUPLICATE_NAME', message } instead of throwing.
 */
function qbo_createCustomer_(displayName, token, realmId, parentId) {
  var body = { "DisplayName": displayName };
  if (parentId) {
    body["Job"] = true;
    body["ParentRef"] = { "value": String(parentId) };
  }

  var result = qbo_apiRequest_("POST", "customer", body, token, realmId);

  if (!result.success) {
    // Check for duplicate name error (QBO error code 6240)
    if (result.data && result.data.Fault && result.data.Fault.Error) {
      for (var i = 0; i < result.data.Fault.Error.length; i++) {
        var err = result.data.Fault.Error[i];
        if (err.code === "6240" || (err.Message && err.Message.indexOf("duplicate") !== -1) ||
            (err.Detail && err.Detail.indexOf("already exists") !== -1)) {
          return { error: "DUPLICATE_NAME", message: err.Detail || err.Message || "Customer name already exists in QBO" };
        }
      }
    }
    throw new Error("QBO customer create failed: " + result.error);
  }

  return result.data && result.data.Customer ? result.data.Customer : result.data;
}

/**
 * Core customer/sub-job resolution. Searches mapping cache → QBO → creates if needed.
 * Returns { customerId: string, isParent: boolean }.
 */
function qbo_resolveCustomerAndSubJob_(clientName, sidemark, token, realmId) {
  var ss = getStaxSpreadsheet_();
  var sheet = ss.getSheetByName("Customers");
  if (!sheet) throw new Error("Customers tab not found in Stax spreadsheet");

  var data = sheet.getDataRange().getValues();
  var headers = data[0];

  // Column indices: A=0(QB Customer Name), H=7(QBO Customer ID), I=8(Sidemark), J=9(QBO Sub-Job ID)
  var COL_QB_NAME = 0;
  var COL_QBO_PARENT_ID = 7;
  var COL_SIDEMARK = 8;
  var COL_QBO_SUBJOB_ID = 9;

  // Ensure columns exist (sheet may not have enough columns yet)
  var lastCol = sheet.getLastColumn();
  if (lastCol < 10) {
    // Extend sheet to have at least 10 columns
    sheet.insertColumnsAfter(lastCol, 10 - lastCol);
    // Add headers if row 1 is short
    if (lastCol < 8)  sheet.getRange(1, 8).setValue("QBO Customer ID");
    if (lastCol < 9)  sheet.getRange(1, 9).setValue("Sidemark");
    if (lastCol < 10) sheet.getRange(1, 10).setValue("QBO Sub-Job ID");
    // Re-read data
    data = sheet.getDataRange().getValues();
  }

  var normalizedClient = String(clientName || "").trim().toUpperCase();
  var normalizedSidemark = String(sidemark || "").trim();
  var hasSidemark = normalizedSidemark.length > 0;

  // --- Find cached parent row (col A matches, col I is blank) ---
  var parentRowIdx = -1;  // 0-based index in data array
  var cachedParentQboId = "";

  // --- Find cached sub-job row (col A matches, col I matches sidemark) ---
  var subJobRowIdx = -1;
  var cachedSubJobQboId = "";

  for (var i = 1; i < data.length; i++) {
    var rowName = String(data[i][COL_QB_NAME] || "").trim().toUpperCase();
    if (rowName !== normalizedClient) continue;

    var rowSidemark = String(data[i][COL_SIDEMARK] || "").trim();
    var rowParentId = String(data[i][COL_QBO_PARENT_ID] || "").trim();
    var rowSubJobId = String(data[i][COL_QBO_SUBJOB_ID] || "").trim();

    if (!rowSidemark) {
      // This is a parent row
      parentRowIdx = i;
      cachedParentQboId = rowParentId;
    } else if (hasSidemark && rowSidemark.toUpperCase() === normalizedSidemark.toUpperCase()) {
      // This is the matching sub-job row
      subJobRowIdx = i;
      cachedSubJobQboId = rowSubJobId;
      // Also capture parent ID if present on this row
      if (rowParentId && !cachedParentQboId) cachedParentQboId = rowParentId;
    }
  }

  // --- No sidemark: resolve parent only ---
  if (!hasSidemark) {
    if (cachedParentQboId) {
      return { customerId: cachedParentQboId, isParent: true };
    }

    // Search QBO for parent
    var existing = qbo_searchCustomer_(clientName, token, realmId);
    var parentId;
    if (existing) {
      parentId = String(existing.Id);
    } else {
      var created = qbo_createCustomer_(clientName, token, realmId, null);
      if (created.error === "DUPLICATE_NAME") {
        throw new Error("QBO duplicate customer: " + created.message + " — resolve in QBO directly");
      }
      parentId = String(created.Id);
    }

    // Cache parent row
    qbo_saveMappingRow_(sheet, data, parentRowIdx, clientName, "", parentId, "");
    return { customerId: parentId, isParent: true };
  }

  // --- Has sidemark: resolve parent + sub-job ---
  if (cachedSubJobQboId) {
    return { customerId: cachedSubJobQboId, isParent: false };
  }

  // Ensure we have the parent QBO ID
  var resolvedParentId = cachedParentQboId;
  if (!resolvedParentId) {
    var parentCust = qbo_searchCustomer_(clientName, token, realmId);
    if (parentCust) {
      resolvedParentId = String(parentCust.Id);
    } else {
      var newParent = qbo_createCustomer_(clientName, token, realmId, null);
      if (newParent.error === "DUPLICATE_NAME") {
        throw new Error("QBO duplicate customer: " + newParent.message + " — resolve in QBO directly");
      }
      resolvedParentId = String(newParent.Id);
    }
    // Cache parent
    qbo_saveMappingRow_(sheet, data, parentRowIdx, clientName, "", resolvedParentId, "");
    // Re-read data after parent write
    data = sheet.getDataRange().getValues();
  }

  // Search QBO for sub-job under parent
  var subJob = qbo_searchSubJob_(normalizedSidemark, resolvedParentId, token, realmId);
  var subJobId;
  if (subJob) {
    subJobId = String(subJob.Id);
  } else {
    var newSubJob = qbo_createCustomer_(normalizedSidemark, token, realmId, resolvedParentId);
    if (newSubJob.error === "DUPLICATE_NAME") {
      throw new Error("QBO duplicate sub-job '" + normalizedSidemark + "' under '" + clientName + "': " + newSubJob.message + " — resolve in QBO directly");
    }
    subJobId = String(newSubJob.Id);
  }

  // Cache sub-job row (separate row from parent)
  qbo_saveMappingRow_(sheet, data, subJobRowIdx, clientName, normalizedSidemark, resolvedParentId, subJobId);

  return { customerId: subJobId, isParent: false };
}

/**
 * Save or update a QBO mapping row in the Stax Customers tab.
 * Only writes cols H/I/J (indices 7/8/9). Never touches A-G.
 */
function qbo_saveMappingRow_(sheet, data, existingRowIdx, clientName, sidemark, parentQboId, subJobQboId) {
  if (existingRowIdx >= 1) {
    // Update existing row (existingRowIdx is 0-based in data array → sheet row = idx + 1)
    var sheetRow = existingRowIdx + 1;
    sheet.getRange(sheetRow, 8).setValue(parentQboId);   // Col H
    sheet.getRange(sheetRow, 9).setValue(sidemark);       // Col I
    sheet.getRange(sheetRow, 10).setValue(subJobQboId);   // Col J
  } else {
    // Append new row — fill col A with clientName, cols H/I/J with QBO data
    // Cols B-G left empty (Stax manages those separately)
    var newRow = [clientName, "", "", "", "", "", "", parentQboId, sidemark, subJobQboId];
    sheet.appendRow(newRow);
  }
}

// ─── QBO Item Resolution ────────────────────────────────────────────────────

/**
 * Load QB_Service_Mapping tab and return { svcCode: { qbItemName, qbAccount } }.
 */
function qbo_loadItemMap_() {
  var cbId = prop_("CB_SPREADSHEET_ID");
  if (!cbId) throw new Error("CB_SPREADSHEET_ID not configured");
  var cbSS = SpreadsheetApp.openById(cbId);
  var mappingSh = cbSS.getSheetByName("QB_Service_Mapping");
  if (!mappingSh || mappingSh.getLastRow() < 2) return {};

  var mapData = mappingSh.getDataRange().getValues();
  var mapHdr = {};
  mapData[0].forEach(function(h, i) { mapHdr[String(h).trim().toUpperCase()] = i; });

  var result = {};
  for (var i = 1; i < mapData.length; i++) {
    var code = String(mapData[i][mapHdr["SVC CODE"]] || "").trim().toUpperCase();
    if (!code) continue;
    result[code] = {
      qbItemName: mapHdr["QB ITEM NAME"] !== undefined ? String(mapData[i][mapHdr["QB ITEM NAME"]] || "").trim() : "",
      qbAccount:  mapHdr["QB INCOME ACCOUNT"] !== undefined ? String(mapData[i][mapHdr["QB INCOME ACCOUNT"]] || "").trim() : ""
    };
  }
  return result;
}

/**
 * Resolve a QBO Item by name. Uses shared itemIdCache to avoid repeat lookups.
 * Returns { value: qboItemId, name: itemName }.
 * Falls back to "Services" item. Throws if no fallback found.
 */
function qbo_resolveItemRef_(qbItemName, token, realmId, itemIdCache) {
  var name = String(qbItemName || "").trim();

  // Check cache first
  if (name && itemIdCache[name]) return itemIdCache[name];

  if (name) {
    // Build search names: try exact name first, then leaf name if it contains ":"
    // QB_Service_Mapping may have "Whse Services:Will Call - Freight" but QBO may
    // have renamed/reorganized to just "Will Call - Freight"
    var searchNames = [name];
    if (name.indexOf(":") >= 0) {
      var leafName = name.substring(name.lastIndexOf(":") + 1).trim();
      if (leafName && leafName !== name) searchNames.push(leafName);
    }

    for (var si = 0; si < searchNames.length; si++) {
      var searchName = searchNames[si];
      if (itemIdCache[searchName]) {
        itemIdCache[name] = itemIdCache[searchName]; // cache under original name too
        return itemIdCache[searchName];
      }

      var escaped = qbo_escapeQueryString_(searchName);
      // Try FullyQualifiedName first for colon-separated, then Name
      var fieldName = searchName.indexOf(":") >= 0 ? "FullyQualifiedName" : "Name";
      var query = "SELECT Id, Name, FullyQualifiedName, Type FROM Item WHERE " + fieldName + " = '" + escaped + "'";
      Logger.log("QBO item query: " + query);
      var result = qbo_apiRequest_("GET", "query?query=" + encodeURIComponent(query), null, token, realmId);

      if (result.success && result.data && result.data.QueryResponse &&
          result.data.QueryResponse.Item && result.data.QueryResponse.Item.length > 0) {
        // Filter out Category items — they can't be used on invoice line items
        var items = result.data.QueryResponse.Item.filter(function(it) {
          return String(it.Type || "").toLowerCase() !== "category";
        });
        if (items.length > 0) {
          var item = items[0];
          var ref = { "value": String(item.Id), "name": item.FullyQualifiedName || item.Name };
          itemIdCache[name] = ref;
          itemIdCache[searchName] = ref;
          Logger.log("QBO item resolved: " + searchName + " → ID " + item.Id + " (Type: " + item.Type + ")");
          return ref;
        }
        Logger.log("QBO item found but is a Category (skipped): " + searchName);
      } else {
        Logger.log("QBO item NOT found: " + searchName + " (field: " + fieldName + ")");
      }
    }
  }

  // Not found — try fallback names in order
  var fallbacks = ["Services", "Service", "Sales"];
  for (var fi = 0; fi < fallbacks.length; fi++) {
    var fb = fallbacks[fi];
    if (fb === name) continue; // already tried
    if (itemIdCache[fb]) return itemIdCache[fb];

    var fbEscaped = qbo_escapeQueryString_(fb);
    var fbQuery = "SELECT Id, Name, FullyQualifiedName, Type FROM Item WHERE Name = '" + fbEscaped + "'";
    var fbResult = qbo_apiRequest_("GET", "query?query=" + encodeURIComponent(fbQuery), null, token, realmId);
    if (fbResult.success && fbResult.data && fbResult.data.QueryResponse &&
        fbResult.data.QueryResponse.Item && fbResult.data.QueryResponse.Item.length > 0) {
      // Filter out categories
      var fbItems = fbResult.data.QueryResponse.Item.filter(function(it) {
        return String(it.Type || "").toLowerCase() !== "category";
      });
      if (fbItems.length === 0) continue;
      var fbItem = fbItems[0];
      var fbRef = { "value": String(fbItem.Id), "name": fbItem.Name };
      itemIdCache[fb] = fbRef;
      Logger.log("QBO item fallback resolved: " + fb + " → ID " + fbItem.Id);
      return fbRef;
    }
  }

  // Nothing found — fatal
  throw new Error("No 'Services', 'Service', or 'Sales' item found in QBO. Please create a Services product/service in QuickBooks Online.");
}

// ─── QBO Invoice Builder + Duplicate Protection ─────────────────────────────

/**
 * Check if a Stride invoice was already pushed to QBO.
 * Returns existing QBO Invoice ID or null.
 */
function qbo_checkDuplicatePush_(strideInvoiceNumber, consolVals, consolHdr) {
  var invCol = consolHdr["INVOICE #"];
  var qboCol = consolHdr["QBO INVOICE ID"];
  if (invCol === undefined || qboCol === undefined) return null;

  for (var i = 1; i < consolVals.length; i++) {
    var inv = String(consolVals[i][invCol] || "").trim();
    if (inv === strideInvoiceNumber) {
      var qboId = String(consolVals[i][qboCol] || "").trim();
      if (qboId) return qboId;
    }
  }
  return null;
}

/**
 * Write QBO Invoice ID + QBO Status back to Consolidated_Ledger for all rows matching an invoice number.
 */
function qbo_writeQboInvoiceId_(strideInvoiceNumber, qboInvoiceId, consolSh, consolVals, consolHdr) {
  var invCol = consolHdr["INVOICE #"];
  var qboCol = consolHdr["QBO INVOICE ID"];
  var qboStatusCol = consolHdr["QBO STATUS"];
  if (invCol === undefined) return;

  for (var i = 1; i < consolVals.length; i++) {
    var inv = String(consolVals[i][invCol] || "").trim();
    if (inv === strideInvoiceNumber) {
      if (qboCol !== undefined) consolSh.getRange(i + 1, qboCol + 1).setValue(qboInvoiceId);
      if (qboStatusCol !== undefined) consolSh.getRange(i + 1, qboStatusCol + 1).setValue("Pushed");
    }
  }
}

/**
 * Write QBO Status = "Failed" + error message for all rows matching an invoice number.
 */
function qbo_writeQboFailure_(strideInvoiceNumber, errorMsg, consolSh, consolVals, consolHdr) {
  var invCol = consolHdr["INVOICE #"];
  var qboStatusCol = consolHdr["QBO STATUS"];
  if (invCol === undefined || qboStatusCol === undefined) return;

  for (var i = 1; i < consolVals.length; i++) {
    var inv = String(consolVals[i][invCol] || "").trim();
    if (inv === strideInvoiceNumber) {
      consolSh.getRange(i + 1, qboStatusCol + 1).setValue("Failed");
    }
  }
}

/**
 * Build a QBO Invoice payload from grouped Stride line items.
 */
function qbo_buildInvoicePayload_(invoiceData, customerQboId, itemMap, token, realmId, itemIdCache) {
  var lines = [];
  for (var li = 0; li < invoiceData.lineItems.length; li++) {
    var item = invoiceData.lineItems[li];
    var mapping = itemMap[item.svcCode] || {};
    var itemRef = qbo_resolveItemRef_(mapping.qbItemName || "Services", token, realmId, itemIdCache);

    lines.push({
      "DetailType": "SalesItemLineDetail",
      "Amount": item.total,
      "Description": item.description,
      "SalesItemLineDetail": {
        "UnitPrice": item.rate,
        "Qty": item.qty,
        "ItemRef": itemRef
      }
    });
  }

  return {
    "CustomerRef": { "value": String(customerQboId) },
    "DocNumber": invoiceData.strideInvoiceNumber,
    "TxnDate": invoiceData.invoiceDate,
    "DueDate": invoiceData.dueDate,
    "PrivateNote": "Pushed from Stride Logistics",
    "Line": lines
  };
}

/**
 * Create an invoice in QBO.
 * Returns { success, qboInvoiceId, qboDocNumber } or { success: false, error }.
 */
function qbo_createInvoice_(invoicePayload, token, realmId) {
  var result = qbo_apiRequest_("POST", "invoice", invoicePayload, token, realmId);

  if (!result.success) {
    return { success: false, error: result.error || "QBO invoice creation failed" };
  }

  var inv = result.data && result.data.Invoice ? result.data.Invoice : result.data;
  return {
    success: true,
    qboInvoiceId: String(inv.Id || ""),
    qboDocNumber: String(inv.DocNumber || "")
  };
}

// ─── QBO Action Handlers ────────────────────────────────────────────────────

/**
 * POST qboCreateInvoice — Push selected invoices to QBO.
 * payload: { ledgerRowIds: string[], forceRePush?: boolean }
 */
function handleQboCreateInvoice_(payload) {
  var ledgerRowIds = payload.ledgerRowIds;
  if (!ledgerRowIds || !Array.isArray(ledgerRowIds) || ledgerRowIds.length === 0) {
    return { success: false, error: "ledgerRowIds array is required" };
  }
  var forceRePush = !!payload.forceRePush;

  // Get QBO credentials
  var token = qbo_getValidToken_();
  var realmId = prop_("QBO_REALM_ID");
  if (!realmId) return { success: false, error: "QBO_REALM_ID missing — please re-authorize" };

  // v38.22.0: Invoice date = today
  var qboTodayDate = new Date();

  // Load CB data
  var cbId = prop_("CB_SPREADSHEET_ID");
  if (!cbId) return { success: false, error: "CB_SPREADSHEET_ID not configured" };
  var cbSS = SpreadsheetApp.openById(cbId);

  // Load item map
  var itemMap = qbo_loadItemMap_();
  var itemIdCache = {};

  // Load client info (for QB customer name + payment terms — same pattern as handleQbExcelExport_)
  var clientsSh = cbSS.getSheetByName("Clients");
  var clientInfoMap = {};
  if (clientsSh && clientsSh.getLastRow() >= 2) {
    var clData = clientsSh.getDataRange().getValues();
    var clHdr = {};
    clData[0].forEach(function(h, i) { clHdr[String(h).trim().toUpperCase()] = i; });
    var clNameIdx = clHdr["CLIENT NAME"];
    var clTermsIdx = clHdr["PAYMENT TERMS"];
    var clQbIdx = clHdr["QB_CUSTOMER_NAME"];
    for (var cli = 1; cli < clData.length; cli++) {
      var clName = String(clData[cli][clNameIdx] || "").trim();
      if (!clName) continue;
      clientInfoMap[clName.toUpperCase()] = {
        terms: clTermsIdx !== undefined ? String(clData[cli][clTermsIdx] || "").trim() : "",
        qbCustomerName: clQbIdx !== undefined ? String(clData[cli][clQbIdx] || "").trim() : ""
      };
    }
  }

  // Read Consolidated_Ledger
  var consolSh = cbSS.getSheetByName("Consolidated_Ledger");
  if (!consolSh) return { success: false, error: "Consolidated_Ledger sheet not found" };
  var consolLR = consolSh.getLastRow();
  if (consolLR < 2) return { success: false, error: "No data in Consolidated_Ledger" };
  var consolVals = consolSh.getRange(1, 1, consolLR, consolSh.getLastColumn()).getValues();
  var consolHdr = {};
  consolVals[0].forEach(function(h, i) { consolHdr[String(h).trim().toUpperCase()] = i; });

  // Build sidemark fallback map (same as handleQbExcelExport_)
  var sidemarkFallback = {};
  try {
    var clientSheetIds = {};
    var cSheetIdx = consolHdr["CLIENT SHEET ID"];
    if (cSheetIdx !== undefined) {
      for (var si = 1; si < consolVals.length; si++) {
        var csid = String(consolVals[si][cSheetIdx] || "").trim();
        if (csid) clientSheetIds[csid] = true;
      }
    }
    for (var csid2 in clientSheetIds) {
      try {
        var clSS = SpreadsheetApp.openById(csid2);
        var blSh = clSS.getSheetByName("Billing_Ledger");
        if (blSh && blSh.getLastRow() >= 2) {
          var blMap = api_getHeaderMap_(blSh);
          var blLidCol = blMap["Ledger Row ID"];
          var blSmCol = blMap["Sidemark"];
          if (blLidCol && blSmCol) {
            var blData = blSh.getRange(2, 1, blSh.getLastRow() - 1, Math.max(blLidCol, blSmCol)).getValues();
            for (var bi = 0; bi < blData.length; bi++) {
              var blLid = String(blData[bi][blLidCol - 1] || "").trim();
              var blSm = String(blData[bi][blSmCol - 1] || "").trim();
              if (blLid && blSm) sidemarkFallback[blLid] = blSm;
            }
          }
        }
      } catch (_) { /* skip inaccessible client sheets */ }
    }
  } catch (_) { /* non-critical */ }

  // Build filter
  var filterIds = {};
  ledgerRowIds.forEach(function(id) { filterIds[String(id).trim()] = true; });

  // Group ledger rows by Invoice #
  var invoiceGroups = {};  // invoiceNo → { clientName, sidemark, lineItems, invoiceDate, dueDate }

  for (var i = 1; i < consolVals.length; i++) {
    var status = String(consolVals[i][consolHdr["STATUS"]] || "").trim().toUpperCase();
    if (status !== "INVOICED") continue;

    if (consolHdr["LEDGER ROW ID"] !== undefined) {
      var lrid = String(consolVals[i][consolHdr["LEDGER ROW ID"]] || "").trim();
      if (!lrid || !filterIds[lrid]) continue;
    }

    var invNo = String(consolVals[i][consolHdr["INVOICE #"]] || "").trim();
    var client = String(consolVals[i][consolHdr["CLIENT"]] || "").trim();
    if (!invNo || !client) continue;

    var rawSvc = consolHdr["SVC CODE"] !== undefined ? consolVals[i][consolHdr["SVC CODE"]] : "";
    var svcCode = (rawSvc instanceof Date) ? "" : String(rawSvc || "").trim().toUpperCase();
    var dateVal = consolHdr["DATE"] !== undefined ? consolVals[i][consolHdr["DATE"]] : "";
    var qty = consolHdr["QTY"] !== undefined ? (Number(consolVals[i][consolHdr["QTY"]]) || 1) : 1;
    var rate = consolHdr["RATE"] !== undefined ? Number(consolVals[i][consolHdr["RATE"]] || 0) : 0;
    var total = Number(consolVals[i][consolHdr["TOTAL"]] || 0);
    var description = consolHdr["DESCRIPTION"] !== undefined ? String(consolVals[i][consolHdr["DESCRIPTION"]] || "").trim() : "";
    var sidemark = consolHdr["SIDEMARK"] !== undefined ? String(consolVals[i][consolHdr["SIDEMARK"]] || "").trim() : "";
    var itemNotes = consolHdr["ITEM NOTES"] !== undefined ? String(consolVals[i][consolHdr["ITEM NOTES"]] || "").trim() : "";
    var itemId = consolHdr["ITEM ID"] !== undefined ? String(consolVals[i][consolHdr["ITEM ID"]] || "").trim() : "";
    var ledgerRowId = consolHdr["LEDGER ROW ID"] !== undefined ? String(consolVals[i][consolHdr["LEDGER ROW ID"]] || "").trim() : "";

    // Sidemark fallback
    if (!sidemark && ledgerRowId && sidemarkFallback[ledgerRowId]) {
      sidemark = sidemarkFallback[ledgerRowId];
    }

    // Build description for QBO (same as Excel export pattern)
    var exportDesc = description;
    if (svcCode === "STOR") {
      var periodStr = "";
      if (itemNotes) {
        var periodMatch = itemNotes.match(/(\d{2}\/\d{2}\/\d{2,4})\s+to\s+(\d{2}\/\d{2}\/\d{2,4})/);
        if (periodMatch) periodStr = periodMatch[1] + " to " + periodMatch[2];
      }
      var parts = [];
      if (periodStr) parts.push("Storage " + periodStr);
      parts.push(qty + " day(s)");
      if (description) parts.push(description);
      if (itemId) parts.push("Item " + itemId);
      exportDesc = parts.join(" — ");
    } else {
      // Non-storage: include sidemark + task/repair/WC info
      var descParts = [];
      if (sidemark) descParts.push(sidemark);
      if (itemId) descParts.push("Item " + itemId);
      if (description) descParts.push(description);
      exportDesc = descParts.join(" — ");
    }

    // Get client info for payment terms
    var clientInfo = clientInfoMap[client.toUpperCase()] || {};
    var qbCustName = clientInfo.qbCustomerName || client;
    var payTerms = clientInfo.terms || "";

    // v38.22.0: Invoice date = today, due date from today (not billing period date)
    var invDateStr = Utilities.formatDate(qboTodayDate, Session.getScriptTimeZone(), "yyyy-MM-dd");
    var dueDateStr = invDateStr;
    var termsMatch = String(payTerms).toUpperCase().match(/NET\s*(\d+)/);
    if (termsMatch) {
      var dueObj = new Date(qboTodayDate.getTime());
      dueObj.setDate(dueObj.getDate() + parseInt(termsMatch[1], 10));
      dueDateStr = Utilities.formatDate(dueObj, Session.getScriptTimeZone(), "yyyy-MM-dd");
    }

    // v38.22.0: Non-storage services — include billing date in description
    if (svcCode !== "STOR") {
      var billingDateStr = api_qbFmtDate_(dateVal);
      if (billingDateStr && exportDesc && !exportDesc.includes(billingDateStr)) {
        exportDesc = exportDesc + " — Billed " + billingDateStr;
      }
    }

    if (!invoiceGroups[invNo]) {
      invoiceGroups[invNo] = {
        strideInvoiceNumber: invNo,
        clientName: qbCustName,
        sidemark: sidemark,
        invoiceDate: invDateStr,
        dueDate: dueDateStr,
        lineItems: [],
        ledgerRowIds: []
      };
    }
    invoiceGroups[invNo].lineItems.push({
      svcCode: svcCode,
      description: exportDesc,
      qty: qty,
      rate: rate,
      total: total
    });
    if (ledgerRowId) invoiceGroups[invNo].ledgerRowIds.push(ledgerRowId);
    // Use the first non-empty sidemark found for this invoice
    if (sidemark && !invoiceGroups[invNo].sidemark) {
      invoiceGroups[invNo].sidemark = sidemark;
    }
  }

  var invoiceNumbers = Object.keys(invoiceGroups);
  if (invoiceNumbers.length === 0) {
    return { success: false, error: "No matching Invoiced rows found for the selected ledger row IDs" };
  }

  // Push each invoice to QBO
  var results = [];
  var pushedCount = 0, skippedCount = 0, failedCount = 0;

  for (var n = 0; n < invoiceNumbers.length; n++) {
    var invNum = invoiceNumbers[n];
    var group = invoiceGroups[invNum];
    var resultEntry = {
      strideInvoiceNumber: invNum,
      success: false,
      skipped: false,
      warning: null,
      existingQboInvoiceId: null,
      qboInvoiceId: null,
      qboDocNumber: null,
      customerName: group.clientName,
      subJobName: group.sidemark || null,
      error: null
    };

    try {
      // Check for duplicate push
      var existingQboId = qbo_checkDuplicatePush_(invNum, consolVals, consolHdr);
      if (existingQboId && !forceRePush) {
        resultEntry.skipped = true;
        resultEntry.existingQboInvoiceId = existingQboId;
        resultEntry.warning = "Already pushed to QBO (ID: " + existingQboId + "). Select force re-push to push again.";
        skippedCount++;
        results.push(resultEntry);
        continue;
      }

      // Resolve customer/sub-job
      var custResult = qbo_resolveCustomerAndSubJob_(group.clientName, group.sidemark, token, realmId);

      // Build and push invoice
      var invoicePayload = qbo_buildInvoicePayload_(group, custResult.customerId, itemMap, token, realmId, itemIdCache);
      var pushResult = qbo_createInvoice_(invoicePayload, token, realmId);

      if (pushResult.success) {
        resultEntry.success = true;
        resultEntry.qboInvoiceId = pushResult.qboInvoiceId;
        resultEntry.qboDocNumber = pushResult.qboDocNumber;
        pushedCount++;

        // Write QBO Invoice ID + status back to Consolidated_Ledger
        qbo_writeQboInvoiceId_(invNum, pushResult.qboInvoiceId, consolSh, consolVals, consolHdr);
      } else {
        resultEntry.error = pushResult.error;
        failedCount++;
        qbo_writeQboFailure_(invNum, pushResult.error, consolSh, consolVals, consolHdr);
      }
    } catch (e) {
      resultEntry.error = e.message || String(e);
      failedCount++;
      try { qbo_writeQboFailure_(invNum, resultEntry.error, consolSh, consolVals, consolHdr); } catch (_) {}
    }

    results.push(resultEntry);

    // Rate limit delay between invoices
    if (n < invoiceNumbers.length - 1) {
      Utilities.sleep(200);
    }
  }

  return {
    success: pushedCount > 0,
    pushedCount: pushedCount,
    skippedCount: skippedCount,
    failedCount: failedCount,
    results: results
  };
}

/**
 * POST qboDisconnect — Clear all QBO OAuth tokens from Script Properties.
 */
function handleQboDisconnect_() {
  var props = PropertiesService.getScriptProperties();
  props.deleteProperty("QBO_ACCESS_TOKEN");
  props.deleteProperty("QBO_REFRESH_TOKEN");
  props.deleteProperty("QBO_REALM_ID");
  props.deleteProperty("QBO_STATE_NONCE");
  return { success: true };
}

/**
 * POST qboSetupHeaders — One-time setup: add QBO columns to Stax Customers tab
 * and Consolidated_Ledger. Safe to run multiple times (checks before adding).
 */
function handleQboSetupHeaders_() {
  var results = [];

  // 1. Add QBO columns to Stax Customers tab (H=QBO Customer ID, I=Sidemark, J=QBO Sub-Job ID)
  try {
    var staxSS = getStaxSpreadsheet_();
    var custSheet = staxSS.getSheetByName("Customers");
    if (!custSheet) {
      results.push("Stax Customers tab: NOT FOUND — skipped");
    } else {
      var lastCol = custSheet.getLastColumn();
      var headerRow = custSheet.getRange(1, 1, 1, Math.max(lastCol, 10)).getValues()[0];

      // Check if QBO headers already exist
      var hasQboHeaders = false;
      for (var i = 0; i < headerRow.length; i++) {
        if (String(headerRow[i]).trim() === "QBO Customer ID") { hasQboHeaders = true; break; }
      }

      if (hasQboHeaders) {
        results.push("Stax Customers tab: QBO headers already exist — skipped");
      } else {
        // Add headers at H1, I1, J1 (or after last col if >7)
        var startCol = Math.max(lastCol + 1, 8); // At least col H
        custSheet.getRange(1, startCol).setValue("QBO Customer ID");
        custSheet.getRange(1, startCol + 1).setValue("Sidemark");
        custSheet.getRange(1, startCol + 2).setValue("QBO Sub-Job ID");
        results.push("Stax Customers tab: Added QBO Customer ID, Sidemark, QBO Sub-Job ID at col " + startCol);
      }
    }
  } catch (e) {
    results.push("Stax Customers tab: ERROR — " + e.message);
  }

  // 2. Add QBO Invoice ID to Consolidated_Ledger
  try {
    var cbId = prop_("CB_SPREADSHEET_ID");
    if (!cbId) {
      results.push("Consolidated_Ledger: CB_SPREADSHEET_ID not configured — skipped");
    } else {
      var cbSS = SpreadsheetApp.openById(cbId);
      var consolSh = cbSS.getSheetByName("Consolidated_Ledger");
      if (!consolSh) {
        results.push("Consolidated_Ledger: sheet not found — skipped");
      } else {
        var consolLastCol = consolSh.getLastColumn();
        var consolHeaders = consolSh.getRange(1, 1, 1, consolLastCol).getValues()[0];

        var hasQboInvCol = false;
        for (var j = 0; j < consolHeaders.length; j++) {
          if (String(consolHeaders[j]).trim().toUpperCase() === "QBO INVOICE ID") { hasQboInvCol = true; break; }
        }

        if (hasQboInvCol) {
          results.push("Consolidated_Ledger: QBO Invoice ID column already exists — skipped");
        } else {
          consolSh.getRange(1, consolLastCol + 1).setValue("QBO Invoice ID");
          results.push("Consolidated_Ledger: Added QBO Invoice ID at col " + (consolLastCol + 1));
          consolLastCol++;
        }

        // Also add QBO Status column
        var hasQboStatusCol = false;
        // Re-read headers in case we just added one
        var updatedHeaders = consolSh.getRange(1, 1, 1, consolSh.getLastColumn()).getValues()[0];
        for (var k = 0; k < updatedHeaders.length; k++) {
          if (String(updatedHeaders[k]).trim().toUpperCase() === "QBO STATUS") { hasQboStatusCol = true; break; }
        }
        if (hasQboStatusCol) {
          results.push("Consolidated_Ledger: QBO Status column already exists — skipped");
        } else {
          consolSh.getRange(1, consolSh.getLastColumn() + 1).setValue("QBO Status");
          results.push("Consolidated_Ledger: Added QBO Status at col " + (consolSh.getLastColumn()));
        }
      }
    }
  } catch (e) {
    results.push("Consolidated_Ledger: ERROR — " + e.message);
  }

  return { success: true, results: results };
}

/**
 * POST updateQboStatus — Manually set QBO Status for a set of ledger row IDs.
 * Payload: { ledgerRowIds: string[], qboStatus: "Pushed"|"Failed"|"" }
 * Setting qboStatus to "" clears it (and optionally clears QBO Invoice ID to allow re-push).
 */
function handleUpdateQboStatus_(payload) {
  var ledgerRowIds = payload.ledgerRowIds || [];
  var newStatus = String(payload.qboStatus || "").trim();
  var clearInvoiceId = payload.clearInvoiceId === true;

  if (!ledgerRowIds.length) return { success: false, error: "No ledger row IDs provided" };

  var cbId = prop_("CB_SPREADSHEET_ID");
  if (!cbId) return { success: false, error: "CB_SPREADSHEET_ID not configured" };

  var cbSS = SpreadsheetApp.openById(cbId);
  var consolSh = cbSS.getSheetByName("Consolidated_Ledger");
  if (!consolSh || consolSh.getLastRow() < 2) return { success: false, error: "Consolidated_Ledger not found or empty" };

  var data = consolSh.getDataRange().getValues();
  var hdr = {};
  data[0].forEach(function(h, i) { hdr[String(h || "").trim().toUpperCase()] = i; });

  var lidIdx = hdr["LEDGER ROW ID"];
  var qboStatusIdx = hdr["QBO STATUS"];
  var qboInvIdx = hdr["QBO INVOICE ID"];
  if (lidIdx === undefined) return { success: false, error: "LEDGER ROW ID column not found" };
  if (qboStatusIdx === undefined) return { success: false, error: "QBO STATUS column not found — run Setup QBO Headers first" };

  var idSet = {};
  ledgerRowIds.forEach(function(id) { idSet[String(id).trim()] = true; });

  var updated = 0;
  for (var i = 1; i < data.length; i++) {
    var lid = String(data[i][lidIdx] || "").trim();
    if (!lid || !idSet[lid]) continue;
    consolSh.getRange(i + 1, qboStatusIdx + 1).setValue(newStatus);
    if (clearInvoiceId && qboInvIdx !== undefined) {
      consolSh.getRange(i + 1, qboInvIdx + 1).setValue("");
    }
    updated++;
  }

  return { success: true, updatedCount: updated };
}

/**
 * GET qboGetCustomers — List all QBO customers for mapping verification.
 */
function handleQboGetCustomers_() {
  var token = qbo_getValidToken_();
  var realmId = prop_("QBO_REALM_ID");
  if (!realmId) return { customers: [], error: "QBO_REALM_ID missing" };

  var query = "SELECT Id, DisplayName, FullyQualifiedName, Job, ParentRef FROM Customer MAXRESULTS 1000";
  var result = qbo_apiRequest_("GET", "query?query=" + encodeURIComponent(query), null, token, realmId);

  if (!result.success) return { customers: [], error: result.error };

  var qr = result.data && result.data.QueryResponse;
  var customers = [];
  if (qr && qr.Customer) {
    for (var i = 0; i < qr.Customer.length; i++) {
      var c = qr.Customer[i];
      customers.push({
        id: String(c.Id || ""),
        displayName: c.DisplayName || "",
        fullyQualifiedName: c.FullyQualifiedName || "",
        job: !!c.Job,
        parentId: c.ParentRef ? String(c.ParentRef.value) : null
      });
    }
  }

  return { customers: customers };
}

// ─── Client Intake Email Handlers ─────────────────────────────────────────────

/**
 * POST sendIntakeInvitation — Admin sends the CLIENT_INTAKE_INVITE email to a
 * prospect after generating a new intake link. Token substitution is done
 * client-side; this handler just sends the pre-composed email.
 *
 * Payload: { to, subject, bodyHtml, linkId }
 *
 * Admin-guarded (withAdminGuard_). Logs the send in Apps Script execution log.
 */
function handleSendIntakeInvitation_(payload) {
  var to       = String(payload.to       || "").trim();
  var subject  = String(payload.subject  || "").trim();
  var bodyHtml = String(payload.bodyHtml || "").trim();
  var linkId   = String(payload.linkId   || "").trim();

  if (!to)       return jsonResponse_({ success: false, error: "Missing 'to' address" });
  if (!subject)  return jsonResponse_({ success: false, error: "Missing email subject" });
  if (!bodyHtml) return jsonResponse_({ success: false, error: "Missing email body" });

  // Basic email format check
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(to)) {
    return jsonResponse_({ success: false, error: "Invalid 'to' address: " + to });
  }

  try {
    GmailApp.sendEmail(to, subject, "", { htmlBody: bodyHtml });
    Logger.log("handleSendIntakeInvitation_: sent intake invite to " + to + " (linkId=" + linkId + ")");
    return jsonResponse_({ success: true, sentTo: to });
  } catch (e) {
    Logger.log("handleSendIntakeInvitation_: GmailApp.sendEmail failed — " + e.message);
    return jsonResponse_({ success: false, error: "Failed to send email: " + e.message });
  }
}

/**
 * POST emailSignedAgreement — Public endpoint (no admin guard).
 * Sends a simple confirmation receipt to a prospect after they sign the T&C
 * on the public intake form. Validates that the linkId actually exists in
 * Supabase client_intake_links as an anti-abuse guard.
 *
 * Payload: { linkId, email, businessName }
 */
function handleEmailSignedAgreement_(payload) {
  var linkId       = String(payload.linkId       || "").trim();
  var email        = String(payload.email        || "").trim();
  var businessName = String(payload.businessName || "").trim();

  if (!linkId)  return { success: false, error: "Missing linkId" };
  if (!email)   return { success: false, error: "Missing email" };

  // Basic email format check
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    return { success: false, error: "Invalid email address: " + email };
  }

  // Anti-abuse: verify linkId exists in Supabase before sending
  var supabaseUrl = prop_("SUPABASE_URL");
  var supabaseKey = prop_("SUPABASE_SERVICE_KEY");
  if (supabaseUrl && supabaseKey) {
    try {
      var checkResp = UrlFetchApp.fetch(
        supabaseUrl + "/rest/v1/client_intake_links?id=eq." + encodeURIComponent(linkId) + "&select=id",
        {
          method: "GET",
          headers: {
            "apikey": supabaseKey,
            "Authorization": "Bearer " + supabaseKey
          },
          muteHttpExceptions: true
        }
      );
      var rows = JSON.parse(checkResp.getContentText() || "[]");
      if (!rows || rows.length === 0) {
        Logger.log("handleEmailSignedAgreement_: linkId not found — " + linkId);
        return { success: false, error: "Invalid linkId" };
      }
    } catch (e) {
      // Supabase check failed — log but continue sending (best-effort)
      Logger.log("handleEmailSignedAgreement_: Supabase link check failed — " + e.message + " — proceeding anyway");
    }
  }

  var displayName = businessName || "your business";
  var subject     = "Your Signed Agreement is on File — Stride Logistics";
  var bodyHtml    = '<!DOCTYPE html>' +
    '<html><head><meta charset="UTF-8"/>' +
    '<style>body{margin:0;padding:0;background:#F5F2EE;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;}' +
    '.wrap{max-width:520px;margin:32px auto;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08);}' +
    '.hdr{background:#1C1C1C;padding:28px 36px;text-align:center;}' +
    '.hdr .lm{display:inline-block;width:44px;height:44px;background:#E8692A;border-radius:9px;line-height:44px;font-size:24px;font-weight:800;color:#fff;margin-bottom:12px;}' +
    '.hdr h1{margin:0;color:#fff;font-size:18px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;}' +
    '.body{padding:32px 36px;}' +
    '.check{text-align:center;font-size:48px;margin:0 0 20px;}' +
    '.msg{font-size:15px;color:#333;line-height:1.65;margin:0 0 20px;}' +
    '.footer{background:#F5F2EE;padding:18px 36px;text-align:center;}' +
    '.footer p{margin:0;font-size:12px;color:#999;}' +
    '</style></head><body>' +
    '<div class="wrap">' +
    '<div class="hdr"><div class="lm">S</div>' +
    '<h1>Agreement Received</h1></div>' +
    '<div class="body">' +
    '<div class="check">✅</div>' +
    '<p class="msg">Hi ' + displayName + ',</p>' +
    '<p class="msg">Your signed Warehousing &amp; Delivery Agreement is now on file with Stride Logistics. ' +
    'We\'ll be in touch shortly to complete your onboarding.</p>' +
    '<p class="msg" style="font-size:13px;color:#666;">If you have any questions, reply to this email or contact us at ' +
    '<a href="mailto:info@stridelogistics.com" style="color:#E8692A;">info@stridelogistics.com</a>.</p>' +
    '</div>' +
    '<div class="footer"><p>Stride Logistics · Kent, WA</p></div>' +
    '</div></body></html>';

  try {
    GmailApp.sendEmail(email, subject, "", { htmlBody: bodyHtml });
    Logger.log("handleEmailSignedAgreement_: receipt sent to " + email + " (linkId=" + linkId + ")");
    return { success: true };
  } catch (e) {
    Logger.log("handleEmailSignedAgreement_: GmailApp.sendEmail failed — " + e.message);
    return { success: false, error: "Failed to send receipt: " + e.message };
  }
}
